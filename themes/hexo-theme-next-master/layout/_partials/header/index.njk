<div class="header-inner">
  <div class="site-brand-container">
    <a href="{{ config.root }}" class="brand" rel="start">
      <span class="site-title">{{ title }}</span>
    </a>
  </div>

  {%- if theme.menu %}
  <nav class="site-nav">
    <ul class="main-menu menu">
      {%- for name, link in theme.menu %}
        {%- set menuItem = link.split('||')[0] | trim %}
        {%- set menuIcon = link.split('||')[1] | trim if link.split('||')[1] else '' %}
        <li class="menu-item">
          <a href="{{ url_for(menuItem) }}" {% if page.path === menuItem or (is_home() and menuItem === '/') %}class="menu-item-active"{% endif %}>
            {%- if theme.menu_settings.icons and menuIcon %}<i class="{{ menuIcon }}"></i>{% endif %}
            {{ __('menu.' + name) }}
          </a>
        </li>
      {%- endfor %}

      {%- if theme.algolia_search.enable or theme.local_search.enable %}
      <li class="menu-item menu-item-search">
        <a role="button" class="popup-trigger">
          {%- if theme.menu_settings.icons %}<i class="fa fa-search fa-fw"></i>{% endif %}{{ __('menu.search') }}
        </a>
      </li>
      {%- endif %}
    </ul>
  </nav>
  {%- endif %}
</div>
